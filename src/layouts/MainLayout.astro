---
import '../styles/global.css';
import { siteConfig } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://cognilab.com.ar';

interface Props {
  title?: string;
  description?: string;
  hideWhatsapp?: boolean;
  ogImage?: string;
}

const {
  title = `${siteConfig.name} | ${siteConfig.tagline}`,
  description = siteConfig.description,
  hideWhatsapp = false,
  ogImage = `${siteUrl}/logos/og-image.svg`
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": ["MedicalBusiness", "LocalBusiness"],
  "name": siteConfig.name,
  "description": siteConfig.description,
  "url": siteUrl,
  "telephone": siteConfig.phone,
  "email": siteConfig.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": siteConfig.address,
    "addressCountry": "AR"
  },
  "openingHours": "Mo-Fr 09:00-19:00",
  "medicalSpecialty": ["Psicología", "Psicopedagogía"],
  "image": ogImage,
  "sameAs": [siteConfig.instagram],
  "priceRange": "$$"
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#660c9f" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Agbalumo&family=DM+Sans:wght@400;500;600;700&family=Fredoka:wght@400;500;600;700&family=Tilt+Neon&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href={`${base}/logos/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}/logos/favicon.svg`} />
  </head>
  <body>
    <slot />

    {!hideWhatsapp && <div class="fab-group">
      <a
        href={siteConfig.instagram}
        class="fab fab--instagram"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Seguinos en Instagram"
        title="Instagram"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
          <path d="M8 12a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"/>
          <path d="M17.5 6.5h.01"/>
        </svg>
      </a>
      <a
        href={`https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent(siteConfig.whatsappMessage)}`}
        class="fab fab--whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp"
        title="WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
      </a>
    </div>}
  </body>
</html>

<style>
  .fab-group {
    position: fixed;
    bottom: max(1.5rem, calc(env(safe-area-inset-bottom) + 1rem));
    right: max(1.5rem, calc(env(safe-area-inset-right) + 1rem));
    z-index: 999;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    align-items: center;
  }

  .fab {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .fab:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
  }

  .fab svg {
    width: 1.4rem;
    height: 1.4rem;
    flex-shrink: 0;
  }

  .fab--instagram {
    background: var(--gradient-instagram);
  }

  .fab--whatsapp {
    background: var(--color-primary);
  }
</style>
