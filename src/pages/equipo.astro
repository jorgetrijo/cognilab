---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Professionals from '../components/Professionals.astro';
import { siteConfig } from '../data/site';
---

<MainLayout
  title={`Nuestro equipo | ${siteConfig.name}`}
  description="Conocé al equipo interdisciplinario de CogniLab: psicólogos y psicopedagogos comprometidos con cada proceso."
>
  <Header />

  <main>
    <Professionals />

  </main>

  <Footer />
</MainLayout>

<style>
  main > :global(#profesionales) {
    padding-top: 2rem;
  }
</style>
