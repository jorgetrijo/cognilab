---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { services, siteConfig } from '../data/site';

const accentColors = [
  'var(--color-primary)',
  'var(--color-secondary-strong)',
  'var(--color-purple)',
  'var(--color-pink)',
  'var(--color-orange)',
  'var(--color-secondary)'
];
---

<MainLayout
  title={`Servicios | ${siteConfig.name}`}
  description="Conocé en detalle los servicios de psicología, psicopedagogía y orientación familiar que ofrece CogniLab."
>
  <Header />

  <main>
    <section class="services-detail section">
      <div class="container">
        <h1 class="page-title">Servicios</h1>
        {services.map((service, i) => (
          <article id={service.slug} class="service-item" style={`--accent: ${accentColors[i % accentColors.length]}`}>
            <div class="service-item-header">
              <div class="service-accent-bar"></div>
              <h2>{service.title}</h2>
            </div>

            <div class="service-item-body">
              <div class="service-text">
                <p class="service-lead">{service.description}</p>
                <p>{service.details}</p>
              </div>

              <div class="service-for-whom">
                <p class="for-whom-label">¿Para quién?</p>
                <ul>
                  {service.forWhom.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

  </main>

  <Footer />
</MainLayout>

<style>
  /* ─── Título ─────────────────────────────────────────── */
  .page-title {
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    color: var(--color-text);
    margin: 0 0 2.5rem;
    text-align: center;
  }

  /* ─── Service items ──────────────────────────────────── */
  .services-detail {
    padding-top: 2rem;
  }

  .service-item {
    display: grid;
    gap: 2rem;
    scroll-margin-top: 100px;
    padding: 2.5rem;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-soft);
    margin-bottom: 2rem;
  }

  .service-item:last-child {
    margin-bottom: 0;
  }

  .service-item-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .service-accent-bar {
    width: 0.4rem;
    height: 2.4rem;
    border-radius: 999px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .service-item-header h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin: 0;
  }

  .service-item-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  .service-lead {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .service-for-whom {
    background: rgba(86, 47, 115, 0.04);
    border-radius: var(--radius-md);
    padding: 1.5rem;
  }

  .for-whom-label {
    font-family: var(--font-accent);
    font-size: 0.9rem;
    color: var(--color-primary);
    letter-spacing: 0.04em;
    margin: 0 0 1rem;
  }

  .service-for-whom ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }

  .service-for-whom li {
    padding-left: 1.4rem;
    position: relative;
    color: var(--color-text);
    line-height: 1.5;
  }

  .service-for-whom li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--accent);
  }

  /* ─── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .service-item-body {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .service-item {
      padding: 1.5rem;
    }
  }
</style>
