---
import { siteConfig } from '../data/site';
import Eyebrow from './Eyebrow.astro';
---

<section class="section" id="contacto">
  <div class="container contact-grid">
    <div>
      <Eyebrow label="Contacto" />
      <h2>Estamos para orientarte</h2>
      <p>
        Podés escribirnos para consultas, disponibilidad de turnos o más información sobre el centro.
      </p>

      <ul class="contact-list">
        <li><strong>WhatsApp:</strong> <a href={`https://wa.me/${siteConfig.whatsapp}`} target="_blank" rel="noreferrer">Enviar mensaje</a></li>
        <li><strong>Correo:</strong> <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li><strong>Teléfono:</strong> <a href={`tel:${siteConfig.phone}`}>{siteConfig.phone}</a></li>
        <li><strong>Dirección:</strong> <a href={siteConfig.maps} target="_blank" rel="noreferrer">{siteConfig.address}</a></li>
      </ul>
    </div>

    <div class="contact-card">
      <!-- Formulario -->
      <form id="contact-form" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="2f9f5647-04a8-4134-be4a-aa4feb2e2996" />
        <input type="hidden" name="subject" value="Nueva consulta desde CogniLab" />
        <input type="hidden" name="from_name" value="CogniLab Web" />

        <label>
          Nombre
          <input type="text" name="nombre" placeholder="Tu nombre" required />
        </label>
        <label>
          Teléfono
          <input type="tel" id="telefono" name="telefono" placeholder="Ej: +54 11 1234-5678" pattern="[\+\d\s\-\(\)]{6,20}" title="Solo números, +, espacios o guiones" required />
        </label>
        <label>
          Mensaje
          <textarea name="mensaje" rows="4" placeholder="Contanos tu consulta" required></textarea>
        </label>
        <button class="btn btn-primary" type="submit" id="submit-btn">
          Enviar consulta
        </button>
      </form>

      <!-- Notificación de éxito -->
      <div id="success-msg" class="success-msg" aria-live="polite" hidden>
        <div class="success-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 6L9 17l-5-5" />
          </svg>
        </div>
        <h3>¡Mensaje enviado!</h3>
        <p>Gracias por contactarnos. En breve nos estaremos comunicando con vos.</p>
      </div>

      <!-- Notificación de error -->
      <div id="error-msg" class="error-msg" aria-live="polite" hidden>
        <p>Hubo un problema al enviar tu mensaje. Por favor intentá de nuevo o escribinos por WhatsApp.</p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const telefonoInput = document.getElementById('telefono');
  telefonoInput.addEventListener('input', () => {
    telefonoInput.value = telefonoInput.value.replace(/[^\d\+\s\-\(\)]/g, '');
  });

  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const successMsg = document.getElementById('success-msg');
  const errorMsg = document.getElementById('error-msg');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    errorMsg.hidden = true;

    try {
      const formData = new FormData(form);
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData
      });
      const data = await response.json();

      if (data.success) {
        form.hidden = true;
        successMsg.hidden = false;
      } else {
        throw new Error('Error en el envío');
      }
    } catch {
      errorMsg.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar consulta';
    }
  });
</script>

<style>
  [hidden] { display: none !important; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2rem;
    align-items: center;
  }

  .contact-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-soft);
    padding: 1.5rem;
  }

  form label {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  input,
  textarea {
    width: 100%;
    padding: 0.9rem 1rem;
    border-radius: 16px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    font: inherit;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-focus-ring);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    gap: 0.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    padding: 0.9rem 1.3rem;
    border: none;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease;
  }

  .btn:hover:not(:disabled) {
    transform: translateY(-1px);
  }

  .btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  /* ─── Éxito ───────────────────────────────────────────── */
  .success-msg {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1rem;
    gap: 0.75rem;
    min-height: 280px;
  }

  .success-icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .success-icon svg {
    width: 1.75rem;
    height: 1.75rem;
  }

  .success-msg h3 {
    margin: 0;
    color: var(--color-text);
    font-size: 1.4rem;
  }

  .success-msg p {
    margin: 0;
    color: var(--color-muted);
    max-width: 30ch;
  }

  /* ─── Error ───────────────────────────────────────────── */
  .error-msg {
    margin-top: 0.75rem;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    background: var(--color-error-bg);
    color: var(--color-red);
    font-size: 0.95rem;
    text-align: center;
  }

  .error-msg p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
