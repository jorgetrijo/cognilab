---
import { siteConfig } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(base, '') || '/';

const navItems = [
  { href: `${base}/#inicio`,        label: 'Inicio',         activePath: '/' },
  { href: `${base}/servicios`,      label: 'Servicios',      activePath: '/servicios' },
  { href: `${base}/#profesionales`, label: 'Nuestro equipo' },
  { href: `${base}/#contacto`,      label: 'Contactanos',    cta: true }
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={`${base}/`} aria-label={`Ir al inicio de ${siteConfig.name}`}>
      <img src={`${base}/logos/logo.svg`} alt={siteConfig.name} />
    </a>

    <nav class="desktop-nav" aria-label="Navegación principal">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[{
                'nav-cta': item.cta,
                'is-active': !!item.activePath && currentPath === item.activePath
              }]}
              aria-current={item.activePath && currentPath === item.activePath ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="header-spacer" aria-hidden="true"></div>
  </div>

  <div id="mobile-menu" class="mobile-menu">
    <nav class="mobile-nav" aria-label="Navegación mobile">
      <ul class="mobile-nav-list">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[{ 'is-active': !!item.activePath && currentPath === item.activePath }]}
              aria-current={item.activePath && currentPath === item.activePath ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

    </nav>
  </div>
</header>

<script is:inline>
  const toggle = document.querySelector('.menu-toggle');
  const mobileMenu = document.querySelector('.mobile-menu');

  if (toggle && mobileMenu) {
    toggle.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 246, 241, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(86, 47, 115, 0.08);
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 0 0;
  }

  .header-spacer {
    display: none;
  }

  .brand img {
    width: 180px;
    max-width: 100%;
    object-fit: contain;
    height: 80px;
    padding: 10px 0px 10px 0px;
  }

  .nav-list {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 1.4rem;
    padding: 0;
    margin: 0;
  }

  .nav-list a {
    position: relative;
    font-family: var(--font-heading);
    font-weight: 500;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .nav-list a:hover,
  .nav-list a:focus-visible {
    color: var(--color-primary);
  }

  .nav-list a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.35rem;
    width: 100%;
    height: 0.2rem;
    border-radius: 999px;
    background: linear-gradient(90deg,
      var(--color-red),
      var(--color-orange),
      var(--color-accent),
      var(--color-primary),
      var(--color-secondary),
      var(--color-purple),
      var(--color-pink)
    );
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.2s ease;
  }

  .nav-list a:hover::after,
  .nav-list a:focus-visible::after {
    transform: scaleX(1);
  }

  .nav-list a.nav-cta {
    background: var(--color-primary);
    color: white;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    font-weight: 700;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .nav-list a.nav-cta:hover {
    background: var(--color-primary-strong);
    transform: translateY(-1px);
  }

  .nav-list a.nav-cta::after {
    display: none;
  }

  .nav-list a.is-active::after {
    transform: scaleX(1);
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .social-link {
    width: 2.8rem;
    height: 2.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: #fff;
    box-shadow: var(--shadow-soft);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .social-link:hover,
  .social-link:focus-visible {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  .social-link--instagram {
    background: linear-gradient(135deg, var(--color-pink), var(--color-purple));
    color: white;
    border: 2px solid rgba(255,255,255,0.4);
  }

  .social-link--whatsapp {
    background: var(--color-primary);
    color: white;
    border: 2px solid rgba(255,255,255,0.4);
  }

  .social-link svg {
    width: 1.35rem;
    height: 1.35rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .social-link--whatsapp svg {
    fill: currentColor;
    stroke: none;
  }

  .desktop-nav,
  .desktop-social {
    display: block;
  }

  .menu-toggle {
    display: none;
    width: 48px;
    height: 48px;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.95);
    cursor: pointer;
    padding: 0;
    box-shadow: var(--shadow-soft);
    position: relative;
  }

  .menu-toggle span {
    position: absolute;
    left: 50%;
    width: 22px;
    height: 2.5px;
    background: var(--color-text);
    border-radius: 999px;
    transform: translateX(-50%);
  }

  .menu-toggle span:nth-child(1) { top: 16px; }
  .menu-toggle span:nth-child(2) { top: 22px; }
  .menu-toggle span:nth-child(3) { top: 28px; }

  .mobile-menu {
    display: none;
  }

  .mobile-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* ─── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .header-inner {
      grid-template-columns: 48px 1fr 48px;
      grid-template-rows: 1fr;
      align-items: center;
      gap: 0.75rem;
      padding: 0.8rem 0;
      min-height: 72px;
    }

    .desktop-nav,
    .desktop-social {
      display: none;
    }

    .menu-toggle {
      display: block;
      grid-column: 1;
      grid-row: 1;
      justify-self: start;
      align-self: center;
    }

    .brand {
      grid-column: 2;
      grid-row: 1;
      justify-self: center;
      align-self: center;
      display: inline-flex;
      align-items: center;
    }

    .header-spacer {
      display: block;
      grid-column: 3;
      grid-row: 1;
      width: 48px;
      height: 48px;
    }

    .brand img {
      width: auto;
      height: 46px;
      max-width: 170px;
      object-fit: contain;
    }

    .mobile-menu {
      display: block;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.28s ease;
      background: rgba(250, 246, 241, 0.98);
      border-top: 1px solid rgba(86, 47, 115, 0.08);
    }

    .mobile-menu.is-open {
      max-height: 420px;
    }

    .mobile-nav {
      padding: 0.75rem 0 1.25rem;
    }

    .mobile-nav-list {
      display: grid;
      gap: 0.25rem;
    }

    .mobile-nav-list a {
      display: block;
      padding: 0.9rem 0.25rem;
      font-family: var(--font-heading);
      font-weight: 500;
      color: var(--color-text);
      border-bottom: 1px solid rgba(86, 47, 115, 0.08);
    }

    .mobile-nav-list a.is-active {
      color: var(--color-primary);
      font-weight: 700;
    }

    .mobile-social {
      margin-top: 1rem;
      justify-content: flex-start;
    }
  }

  @media (max-width: 600px) {
    .header-inner {
      grid-template-columns: 44px 1fr 44px;
      min-height: 68px;
    }

    .menu-toggle {
      width: 44px;
      height: 44px;
      border-radius: 14px;
    }

    .menu-toggle span {
      width: 20px;
    }

    .menu-toggle span:nth-child(1) { top: 14px; }
    .menu-toggle span:nth-child(2) { top: 20px; }
    .menu-toggle span:nth-child(3) { top: 26px; }

    .header-spacer {
      width: 44px;
      height: 44px;
    }

    .brand img {
      height: 40px;
      max-width: 145px;
    }

    .social-link {
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>
