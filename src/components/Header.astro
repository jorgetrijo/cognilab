---
import { siteConfig } from '../data/site';

const navItems = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#profesionales', label: 'Nuestro equipo' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#contacto', label: 'Contactanos' }
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="#inicio" aria-label={`Ir al inicio de ${siteConfig.name}`}>
      <img src="/logos/logo.png" alt={siteConfig.name} />
    </a>

    <nav class="desktop-nav" aria-label="Navegación principal">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="social-links desktop-social" aria-label="Redes sociales">
      <a
        class="social-link social-link--instagram"
        href={siteConfig.instagram}
        target="_blank"
        rel="noreferrer"
        aria-label="Instagram"
        title="Instagram"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
          <path d="M8 12a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"></path>
          <path d="M17.5 6.5h.01"></path>
        </svg>
      </a>

      <a
        class="social-link social-link--whatsapp"
        href={`https://wa.me/${siteConfig.whatsapp}`}
        target="_blank"
        rel="noreferrer"
        aria-label="WhatsApp"
        title="WhatsApp"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3.5 20.5l1.4-4.1a8.8 8.8 0 1 1 3.2 3.1l-4.6 1z"></path>
          <path d="M9.4 8.8c.2-.5.4-.5.7-.5h.6c.2 0 .5 0 .7.5c.2.4.8 1.8.8 1.9c.1.1.1.4 0 .6c-.1.2-.2.4-.4.6c-.2.2-.3.4-.5.6c-.2.2-.4.4-.2.7c.2.4.9 1.4 1.8 2.2c1.2 1 2.1 1.3 2.5 1.5c.4.2.6.1.8-.1c.2-.2.8-1 1-1.4c.2-.3.5-.2.8-.1c.3.1 1.8.9 2.1 1c.3.2.5.3.6.4c.1.1.1.8-.2 1.6c-.3.8-1.7 1.5-2.3 1.5c-.6 0-1.3.3-4.2-.8c-2.8-1.1-4.6-3.9-4.8-4.2c-.2-.3-1.1-1.5-1.1-2.9c0-1.4.7-2 .9-2.3z"></path>
        </svg>
      </a>
    </div>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="header-spacer" aria-hidden="true"></div>
  </div>

  <div id="mobile-menu" class="mobile-menu">
    <nav class="mobile-nav" aria-label="Navegación mobile">
      <ul class="mobile-nav-list">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>

      <div class="social-links mobile-social" aria-label="Redes sociales">
        <a
          class="social-link social-link--instagram"
          href={siteConfig.instagram}
          target="_blank"
          rel="noreferrer"
          aria-label="Instagram"
          title="Instagram"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
            <path d="M8 12a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"></path>
            <path d="M17.5 6.5h.01"></path>
          </svg>
        </a>

        <a
          class="social-link social-link--whatsapp"
          href={`https://wa.me/${siteConfig.whatsapp}`}
          target="_blank"
          rel="noreferrer"
          aria-label="WhatsApp"
          title="WhatsApp"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3.5 20.5l1.4-4.1a8.8 8.8 0 1 1 3.2 3.1l-4.6 1z"></path>
            <path d="M9.4 8.8c.2-.5.4-.5.7-.5h.6c.2 0 .5 0 .7.5c.2.4.8 1.8.8 1.9c.1.1.1.4 0 .6c-.1.2-.2.4-.4.6c-.2.2-.3.4-.5.6c-.2.2-.4.4-.2.7c.2.4.9 1.4 1.8 2.2c1.2 1 2.1 1.3 2.5 1.5c.4.2.6.1.8-.1c.2-.2.8-1 1-1.4c.2-.3.5-.2.8-.1c.3.1 1.8.9 2.1 1c.3.2.5.3.6.4c.1.1.1.8-.2 1.6c-.3.8-1.7 1.5-2.3 1.5c-.6 0-1.3.3-4.2-.8c-2.8-1.1-4.6-3.9-4.8-4.2c-.2-.3-1.1-1.5-1.1-2.9c0-1.4.7-2 .9-2.3z"></path>
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  const toggle = document.querySelector('.menu-toggle');
  const mobileMenu = document.querySelector('.mobile-menu');

  if (toggle && mobileMenu) {
    toggle.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>