---
import { specialties } from '../data/site';
import Eyebrow from './Eyebrow.astro';
---

<section class="section section--alt" id="servicios">
  <div class="container">
    <div class="section-heading section-heading--center">
      <Eyebrow label="Áreas de trabajo" />
      <h2>Nuestras especialidades</h2>
    </div>
    <div class="specialty-grid">
      {specialties.map((s) => (
        <article class="specialty-card">
          <h3>{s.title}</h3>
          <p>{s.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .specialty-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .specialty-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    border-top: 0.45rem solid var(--color-primary);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-soft);
    padding: 1.5rem;
  }

  .specialty-card:nth-child(2) { border-top-color: var(--color-secondary-strong); }

  .specialty-card h3 {
    margin: 0 0 0.75rem;
    font-size: 1.3rem;
  }

  .specialty-card p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .specialty-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
