---
import { siteConfig } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="inicio" class="hero section">
  <div class="container hero-grid">
    <div class="hero-content">
      <h1>{siteConfig.name}</h1>
      <p class="hero-description">{siteConfig.description}</p>
    </div>

    <div class="hero-card">
      <img src={`${base}/images/hero-espacio.jpg`} alt="Espacio del centro" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 2rem 0 5rem;
    scroll-margin-top: 80px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2rem;
    align-items: center;
  }

  .hero-content {
    max-width: 640px;
  }

  .hero-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 4vw, 4.4rem);
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: 1rem;
    max-width: 12ch;
  }

  .hero-description {
    max-width: 58ch;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .hero-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    height: min(60vh, 520px);
    min-height: 320px;
  }

  .hero-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ─── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 2rem;
    }

    .hero-content {
      order: 1;
      max-width: 100%;
    }

    .hero-content h1 {
      max-width: 100%;
    }

    .hero-card {
      order: 2;
      height: 42vh;
      min-height: 280px;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 3rem 0 4rem;
    }

    .hero-content h1 {
      font-size: clamp(2.2rem, 9vw, 3.4rem);
    }

    .hero-description {
      font-size: 1rem;
      line-height: 1.65;
    }

    .hero-card {
      height: 36vh;
      min-height: 240px;
      border-radius: 22px;
    }
  }
</style>
