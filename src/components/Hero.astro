---
import { siteConfig } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="inicio" class="hero section">
  <div class="container hero-grid">
    <div class="hero-content">
      <span class="hero-badge">{siteConfig.tagline}</span>

      <h1>{siteConfig.name}</h1>
      <p class="hero-description">{siteConfig.description}</p>

      <div class="hero-actions">
        <a href="#contacto" class="btn btn-primary">Contactanos</a>
        <a href="#servicios" class="btn btn-secondary">Ver servicios</a>
      </div>
    </div>

    <div class="hero-card">
      <img src={`${base}/images/hero-espacio.jpg`} alt="Espacio del centro" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 2rem 0 5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2rem;
    align-items: center;
  }

  .hero-content {
    max-width: 640px;
  }

  .hero-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 4vw, 4.4rem);
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: 1rem;
    max-width: 12ch;
  }

  .hero-badge {
    display: inline-block;
    margin-bottom: 1rem;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-text);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    border: 1px solid var(--color-border);
  }

  .hero-description {
    max-width: 58ch;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .hero-card {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    height: min(60vh, 520px);
    min-height: 320px;
    border-radius: 28px;
    background: white;
  }

  .hero-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.9rem 1.3rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--color-text);
    color: white;
  }

  .btn-secondary {
    background: white;
    color: var(--color-text);
    border: 2px solid var(--color-text);
  }

  /* ─── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 2rem;
    }

    .hero-content {
      order: 1;
      max-width: 100%;
    }

    .hero-content h1 {
      max-width: 100%;
    }

    .hero-card {
      order: 2;
      height: 42vh;
      min-height: 280px;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 3rem 0 4rem;
    }

    .hero-content h1 {
      font-size: clamp(2.2rem, 9vw, 3.4rem);
    }

    .hero-description {
      font-size: 1rem;
      line-height: 1.65;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      width: 100%;
    }

    .hero-card {
      height: 36vh;
      min-height: 240px;
      border-radius: 22px;
    }
  }
</style>
