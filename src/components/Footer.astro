---
import { siteConfig } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="site-footer">
  <div class="container footer-inner">
    <a class="footer-brand" href={`${base}/`} aria-label="Ir al inicio">
      <img src={`${base}/logos/logo.svg`} alt={siteConfig.name} />
    </a>

    <nav class="footer-links" aria-label="Contacto">
      <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href={`https://wa.me/${siteConfig.whatsapp}`} target="_blank" rel="noreferrer">{siteConfig.phone}</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href={siteConfig.maps} target="_blank" rel="noreferrer">Belgrano, CABA</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(255,255,255,0.25), rgba(255,255,255,0.55));
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand img {
    width: 80px;
    height: auto;
    object-fit: contain;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--color-muted);
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-text);
  }

  .sep {
    color: var(--color-border);
    font-size: 1.1rem;
    user-select: none;
  }

  @media (max-width: 700px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer-links {
      flex-direction: column;
      gap: 0.5rem;
    }

    .sep {
      display: none;
    }
  }
</style>
