---
import { professionals } from '../data/site';
---

<section class="section section--alt" id="profesionales">
  <div class="container">
    <div class="section-heading section-heading--center">
      <p class="eyebrow">Equipo</p>
      <h2>Profesionales del centro</h2>
      <p class="section-description">
        Un equipo interdisciplinario que acompaña cada proceso con cercanía,
        compromiso y una mirada integral.
      </p>
    </div>

    <div class="profile-grid">
      {professionals.map((professional) => (
        <article class="profile-card">
          <div class="profile-image-wrap">
            <img src={professional.image} alt={professional.name} loading="lazy" />
          </div>

          <div class="profile-content">
            <p class="role">{professional.role}</p>
            <h3>{professional.name}</h3>
            <p class="profile-bio">{professional.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .profile-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .profile-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .profile-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 54px rgba(86, 47, 115, 0.16);
  }

  .profile-image-wrap {
    padding: 1rem 1rem 0;
  }

  .profile-image-wrap img {
    width: 100%;
    aspect-ratio: 4 / 4.2;
    object-fit: cover;
    border-radius: 22px;
    background: #fff;
  }

  .profile-content {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.25rem 1.25rem 1.4rem;
  }

  .role {
    display: inline-flex;
    align-self: flex-start;
    margin: 0;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: rgba(86, 47, 115, 0.08);
    color: var(--color-text);
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1;
  }

  .profile-content h3 {
    margin: 0;
    font-size: 1.45rem;
    color: var(--color-text);
  }

  .profile-bio {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.7;
    font-size: 1rem;
  }

  /* ─── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .profile-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .profile-image-wrap {
      padding: 0.9rem 0.9rem 0;
    }

    .profile-content {
      padding: 1rem 1rem 1.2rem;
    }

    .profile-content h3 {
      font-size: 1.3rem;
    }
  }
</style>
