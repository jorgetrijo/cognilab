---
import { professionals } from '../data/site';
import Eyebrow from './Eyebrow.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="section section--alt" id="profesionales">
  <div class="container">
    <div class="section-heading section-heading--center">
      <Eyebrow label="Equipo" />
      <h2>Profesionales del centro</h2>
      <p class="section-description">
        Un equipo interdisciplinario que acompaña cada proceso con cercanía,
        compromiso y una mirada integral.
      </p>
    </div>

    <div class="profile-grid" id="profile-carousel">
      {professionals.map((professional) => (
        <article class="profile-card">
          <div class="profile-image-wrap">
            <img src={`${base}${professional.image}`} alt={professional.name} loading="lazy" />
          </div>

          <div class="profile-content">
            <p class="role">{professional.role}</p>
            <h3>{professional.name}</h3>
            <p class="profile-bio">{professional.bio}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="carousel-dots" id="carousel-dots" aria-hidden="true">
      {professionals.map((_, i) => (
        <button class:list={['dot', { 'dot--active': i === 0 }]} data-index={i} aria-label={`Ver profesional ${i + 1}`} />
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const grid = document.getElementById('profile-carousel');
    const dotsContainer = document.getElementById('carousel-dots');
    if (!grid || !dotsContainer) return;

    const dots = dotsContainer.querySelectorAll('.dot');
    const cards = grid.querySelectorAll('.profile-card');

    function updateDots() {
      const scrollLeft = grid.scrollLeft;
      const cardWidth = cards[0]?.offsetWidth + 16; // gap
      const index = Math.round(scrollLeft / cardWidth);
      dots.forEach((d, i) => d.classList.toggle('dot--active', i === index));
    }

    grid.addEventListener('scroll', updateDots, { passive: true });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        const cardWidth = cards[0]?.offsetWidth + 16;
        grid.scrollTo({ left: cardWidth * i, behavior: 'smooth' });
      });
    });
  })();
</script>

<style>
  .profile-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .profile-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .profile-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }

  .profile-image-wrap {
    padding: 1rem 1rem 0;
  }

  .profile-image-wrap img {
    width: 100%;
    aspect-ratio: 4 / 4.2;
    object-fit: cover;
    border-radius: 22px;
    background: var(--color-surface);
  }

  .profile-content {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.25rem 1.25rem 1.4rem;
  }

  .role {
    display: inline-flex;
    align-self: flex-start;
    margin: 0;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: var(--color-border-subtle);
    color: var(--color-text);
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1;
  }

  .profile-content h3 {
    margin: 0;
    font-size: 1.45rem;
    color: var(--color-text);
  }

  .profile-bio {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.7;
    font-size: 1rem;
  }

  /* ─── Dots ───────────────────────────────────────────── */
  .carousel-dots {
    display: none;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: none;
    background: var(--color-border);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease, transform 0.2s ease, width 0.2s ease;
  }

  .dot--active {
    background: var(--color-primary);
    width: 1.4rem;
    border-radius: 999px;
  }

  /* ─── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .profile-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      gap: 1rem;
      padding-bottom: 0.5rem;
    }

    .profile-grid::-webkit-scrollbar {
      display: none;
    }

    .profile-card {
      flex: 0 0 82%;
      scroll-snap-align: center;
    }

    .carousel-dots {
      display: flex;
    }
  }

  @media (max-width: 600px) {
    .profile-card {
      flex: 0 0 88%;
    }

    .profile-image-wrap {
      padding: 0.9rem 0.9rem 0;
    }

    .profile-content {
      padding: 1rem 1rem 1.2rem;
    }

    .profile-content h3 {
      font-size: 1.3rem;
    }
  }
</style>
