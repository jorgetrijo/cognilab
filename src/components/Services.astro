---
import { services } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="section" id="servicios">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Servicios</p>
      <h2>Acompañamiento profesional según cada necesidad</h2>
    </div>

    <div class="card-grid">
      {services.map((service) => (
        <article class="card">
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>

    <div class="services-footer">
      <a href={`${base}/servicios`} class="btn-more">Ver todos los servicios</a>
    </div>
  </div>
</section>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    padding: 1.5rem;
  }

  .card:nth-child(1) { border-top: 0.45rem solid var(--color-primary); }
  .card:nth-child(2) { border-top: 0.45rem solid var(--color-secondary-strong); }
  .card:nth-child(3) { border-top: 0.45rem solid var(--color-green); }

  .services-footer {
    margin-top: 2.5rem;
    text-align: center;
  }

  .btn-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    border-radius: 999px;
    background: var(--color-text);
    color: white;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .btn-more:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
